#!/usr/bin/env bash
# Configures localhost to resolve to 127.0.0.2 and facebook.com to 8.8.8.8
python3 -c "
content = open('/etc/hosts').read()
content = content.replace('127.0.0.1\tlocalhost', '127.0.0.2\tlocalhost')
content = content.replace('127.0.0.1 localhost', '127.0.0.2 localhost')
open('/etc/hosts', 'w').write(content)
"
echo "8.8.8.8 facebook.com" >> /etc/hosts
